# =====================================================
# ISTHO CRM - Variables de Entorno (Producción - Railway)
# =====================================================

NODE_ENV=production
API_PREFIX=/api/v1

# Base de datos (Railway MySQL plugin)
MYSQL_URL=${{MySQL.MYSQL_URL}}
# O variables individuales:
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_NAME=${{MySQL.MYSQLDATABASE}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_USER=${{MySQL.MYSQLUSER}}

# JWT
JWT_SECRET=GENERAR_SECRETO_SEGURO
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# URL del frontend (para botones en emails)
APP_URL=https://tu-app.vercel.app

# CORS (URL exacta de Vercel, sin / al final)
CORS_ORIGIN=https://tu-app.vercel.app

# Email (Resend - recomendado para Railway, no requiere SMTP)
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM=notificaciones@istho.com.co

# Rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info

# Uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
